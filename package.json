{
  "name": "options-scout",
  "version": "1.2.8",
  "description": "Find this week's best call options — ranked by levels, S/R, volume, and live news.",
  "main": "electron/main.js",
  "author": "415evan",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.evan.optionsscout",
    "productName": "Options Scout",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "backend/**/*",
      "!backend/__pycache__",
      "!backend/.venv",
      "!**/.DS_Store"
    ],
    "extraResources": [
      { "from": "backend/dist/optionsscout-backend", "to": "backend-bin", "filter": ["**/*"] },
      { "from": "frontend", "to": "frontend", "filter": ["**/*"] }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": "-"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico",
      "artifactName": "Options-Scout-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [{
      "provider": "github",
      "owner": "415evan",
      "repo": "options-scout"
    }]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.2.1",
    "electron-log": "^5.1.5"
  }
}
